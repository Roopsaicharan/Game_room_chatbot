NAVIGATOR_API_KEY=sk-your-api-key-here
NAVIGATOR_BASE_URL=https://api.ai.it.ufl.edu/v1
CHROMA_URL=http://localhost:8000
SESSION_SECRET=replace-with-a-long-random-string
PORT=3000

# Optional tuning
RELEVANCE_THRESHOLD=0.35
LIVE_CACHE_TTL_MINUTES=30

# Reservation request flow (pre-launch/test feature) — see Backend/services/reservationFlow.js
# RESERVATION_FORM_PROVIDER: 'google-forms' (throwaway dev/test target) or 'qualtrics' (the real
# UF form). RESERVATION_FORM_URL: the live form URL to fill/submit. RESERVATION_ALLOW_REAL_SUBMIT:
# the hard safety gate — must be the literal string "true" (not "1"/"yes") before the qualtrics
# adapter will ever click the real form's final Submit button; leave unset/false while testing.
RESERVATION_FORM_PROVIDER=google-forms
RESERVATION_FORM_URL=
RESERVATION_ALLOW_REAL_SUBMIT=false
